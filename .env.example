# Supabase — https://supabase.com/dashboard → Settings → API
# Project URL + chave anon (JWT com role "anon"). Nunca commite service_role nem use-a no cliente.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Opcional: redirects e links absolutos (ex.: http://localhost:3000 em dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
